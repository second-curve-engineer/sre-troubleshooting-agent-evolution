TRACE_DIR=traces

# LLM 模式：mock（默认，不调真实 API）或 openai（调 OpenAI-compatible API）
LLM_MODE=mock

# 必填：所有档位的默认模型，只配这一个即可跑通所有 LLM 调用
LLM_STANDARD_MODEL=gpt-5.4

# 可选：按档位差异化配置，不填则 fallback 到 LLM_STANDARD_MODEL
LLM_SMALL_MODEL=gpt-5.4-mini
LLM_STRONG_MODEL=gpt-5.5

LLM_TIMEOUT_MS=15000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

TOOL_TIMEOUT_MS=3000
TOOL_MAX_ATTEMPTS=2
TOOL_RETRY_DELAY_MS=100
