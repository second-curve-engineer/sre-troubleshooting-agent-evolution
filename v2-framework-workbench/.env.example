# OpenAI-compatible LLM config.
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Runtime config.
AGENT_HOST=0.0.0.0
AGENT_PORT=7777
AGENT_RELOAD=true
AGENT_DEBUG=false

# Mock mode keeps the public demo runnable without internal systems.
LOG_QUERY_MODE=mock
ENABLE_CLAUDE_CODE=false

# Optional simple codebase paths used by ask_codebase.
CODEBASE_ORDER_SERVICE=/path/to/order-service
CODEBASE_INVENTORY_SERVICE=/path/to/inventory-service
CODEBASE_PAYMENT_SERVICE=/path/to/payment-service

# Multi-app codebase configuration.
# In a real internal system, users often mention nicknames such as "库存"
# while log/code tools need the exact appId, appname and repository path.
CODEBASE_PATH=/path/to/codebases

APP_CODEBASE_MAPPING="
| appId                         | 系统名称          | 代码库路径 (base_dir)             |
| ----------------------------- | ----------------- | --------------------------------- |
| demo.platform.order-service    | 订单系统          | ${CODEBASE_PATH}/order-service    |
| demo.platform.inventory-service| 库存系统          | ${CODEBASE_PATH}/inventory-service|
| demo.platform.payment-service  | 支付系统          | ${CODEBASE_PATH}/payment-service  |
"

APP_MAPPINGS='[
  {"appid": "demo.platform.order-service", "appname": "order-service", "realname": "order"},
  {"appid": "demo.platform.inventory-service", "appname": "inventory-service", "realname": "inventory"},
  {"appid": "demo.platform.payment-service", "appname": "payment-service", "realname": "payment"}
]'
